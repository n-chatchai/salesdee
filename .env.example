# Copy to .env and fill in. Never commit .env.

DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-prod
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
DATABASE_URL=postgres://quotation:quotation@localhost:5432/quotation

# Redis (Django cache backend; optional in dev)
REDIS_URL=redis://localhost:6379/0

# Email (dev: console backend)
EMAIL_URL=consolemail://

# LINE Messaging API (per-tenant tokens are stored in DB; this is for the platform's own OA if any)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Base URL for building public links (e.g. customer quote-view links)
SITE_BASE_URL=http://localhost:8000

# Default tenant for local dev convenience (optional)
DEV_DEFAULT_TENANT_SLUG=
